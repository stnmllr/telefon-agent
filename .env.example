# ============================================================
# .env.example – lokale Entwicklung
# Produktionswerte NIEMALS committen!
# In GCP: Werte aus Secret Manager laden
# ============================================================

ENVIRONMENT=development

# GCP
GCP_PROJECT_ID=mein-gcp-projekt-id
GCP_LOCATION=europe-west3

# Vertex AI
GEMINI_MODEL=gemini-1.5-pro-002
VERTEX_SEARCH_DATASTORE=handbuecher

# Twilio (aus Twilio Console)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+49xxxxxxxxxx

# STT
STT_LANGUAGE=de-DE
STT_MODEL=chirp

# TTS
TTS_VOICE=de-DE-Neural2-F
TTS_SPEAKING_RATE=1.0

# RAG / LLM
RAG_TOP_K=5
RAG_MAX_TOKENS=200
LLM_TEMPERATURE=0.0
